{
  "name": "restaurant-service",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "./scripts/run-all.sh",
    "dev:api": "./scripts/run-api.sh",
    "dev:business": "./scripts/run-business-web.sh",
    "dev:customer": "./scripts/run-customer-web.sh",
    "dev:all": "./scripts/run-all.sh",
    "dev:stop": "./scripts/stop-dev.sh",
    "build": "pnpm --filter @restaurant/business-web build",
    "build:business": "pnpm --filter @restaurant/business-web build",
    "build:customer": "pnpm --filter @restaurant/customer-web build",
    "test": "pnpm --filter @restaurant/business-web test",
    "test:api": "cd apps/api && ./gradlew test",
    "test:business": "pnpm --filter @restaurant/business-web test",
    "test:customer": "pnpm --filter @restaurant/customer-web test",
    "test:e2e:business": "pnpm --filter @restaurant/business-web test:e2e",
    "test:e2e:customer": "pnpm --filter @restaurant/customer-web test:e2e",
    "qa:regression:api": "cd apps/api && ./gradlew test",
    "qa:regression": "./qa-regression.sh",
    "lint": "pnpm --filter @restaurant/business-web lint",
    "lint:business": "pnpm --filter @restaurant/business-web lint",
    "lint:customer": "pnpm --filter @restaurant/customer-web lint",
    "format": "pnpm --filter @restaurant/business-web format"
  }
}
